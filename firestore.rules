rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)/profile/main).data;
    }

    function hasProfile(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/profile/main);
    }

    function profileHasPartner(profile, partnerId) {
      return profile != null && partnerId is string && (
        (profile.partnerId is string && profile.partnerId == partnerId) ||
        (profile.activePartnerId is string && profile.activePartnerId == partnerId) ||
        (profile.partnerIds is list && partnerId in profile.partnerIds)
      );
    }

    function linkedPartnerId(userId) {
      let profile = getProfile(userId);
      return profile == null
        ? null
        : (
          profile.activePartnerId is string && profile.activePartnerId.size() > 0
            ? profile.activePartnerId
            : (
              profile.partnerId is string && profile.partnerId.size() > 0
                ? profile.partnerId
                : (
                  profile.partnerIds is list && profile.partnerIds.size() > 0
                    ? profile.partnerIds[0]
                    : null
                )
            )
        );
    }

    function isPartnerOf(userId) {
      let profile = getProfile(userId);
      return isAuthenticated() && profileHasPartner(profile, request.auth.uid);
    }

    function callerHasLinkedTarget(targetUserId) {
      let callerProfile = getProfile(request.auth.uid);
      return callerProfile != null && profileHasPartner(callerProfile, targetUserId);
    }

    function targetHasLinkedCaller(targetUserId) {
      let targetProfile = getProfile(targetUserId);
      return targetProfile != null && profileHasPartner(targetProfile, request.auth.uid);
    }

    function allowedUserMetadataFields() {
      return [
        'email',
        'displayName',
        'createdAt',
        'updatedAt',
        'lastSyncedAt',
        'lastAliasUpdate'
      ];
    }

    function allowedAliasFields() {
      return ['userId', 'displayName', 'createdAt', 'updatedAt'];
    }

    // Profile documents are private by default.
    // Only owner and currently linked partner can read.
    match /users/{userId}/profile/{document=**} {
      allow get: if isOwner(userId) || isPartnerOf(userId);
      allow list: if false;
      allow write: if isOwner(userId);
    }

    // Workout history
    match /users/{userId}/workoutHistory/{workoutId} {
      allow read: if isOwner(userId) || isPartnerOf(userId);
      allow write: if isOwner(userId);
      // Allow partner to create mirrored workout entries.
      allow create: if isPartnerOf(userId);
    }

    // Routine history
    match /users/{userId}/routineHistory/{routineId} {
      allow read: if isOwner(userId) || isPartnerOf(userId);
      allow write: if isOwner(userId);
    }

    // Extra activities
    match /users/{userId}/extraActivities/{activityId} {
      allow read: if isOwner(userId) || isPartnerOf(userId);
      allow write: if isOwner(userId);
    }

    // Alias lookup: allow direct document lookup, disallow enumeration.
    match /userAliases/{alias} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasOnly(allowedAliasFields());
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.keys().hasOnly(allowedAliasFields());
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // User metadata: owner-only read/write with field allowlist.
    // Prevents client-side privilege escalation via mutable role-like fields.
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly(allowedUserMetadataFields());
      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(allowedUserMetadataFields());
      allow delete: if false;
    }

    // FCM tokens
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if isOwner(userId);
    }

    // Exercise catalog - admin only via Firebase custom claims.
    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.token.admin == true;
    }

    // Link requests
    match /linkRequests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );

      allow create: if isAuthenticated() &&
        request.resource.data.requesterId == request.auth.uid &&
        request.resource.data.requesterId is string &&
        request.resource.data.recipientId is string &&
        request.resource.data.requesterAlias is string &&
        request.resource.data.recipientAlias is string &&
        request.resource.data.createdAt is string &&
        request.resource.data.status == 'pending' &&
        request.resource.data.requesterId != request.resource.data.recipientId &&
        request.resource.data.keys().hasOnly([
          'requesterId',
          'requesterAlias',
          'recipientId',
          'recipientAlias',
          'status',
          'createdAt'
        ]) &&
        hasProfile(request.resource.data.requesterId) &&
        hasProfile(request.resource.data.recipientId) &&
        (
          linkedPartnerId(request.auth.uid) == null ||
          linkedPartnerId(request.auth.uid) == request.resource.data.recipientId
        ) &&
        (
          linkedPartnerId(request.resource.data.recipientId) == null ||
          linkedPartnerId(request.resource.data.recipientId) == request.auth.uid
        );

      allow update: if isAuthenticated() && (
        (
          // Recipient can accept/decline pending request.
          resource.data.recipientId == request.auth.uid &&
          resource.data.status == 'pending' &&
          request.resource.data.status in ['accepted', 'declined'] &&
          request.resource.data.requesterId == resource.data.requesterId &&
          request.resource.data.recipientId == resource.data.recipientId &&
          request.resource.data.requesterAlias == resource.data.requesterAlias &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.keys().hasOnly([
            'requesterId',
            'requesterAlias',
            'recipientId',
            'recipientAlias',
            'status',
            'createdAt',
            'resolvedAt',
            'updatedAt'
          ])
        ) ||
        (
          // Requester can cancel pending request.
          resource.data.requesterId == request.auth.uid &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'cancelled' &&
          request.resource.data.requesterId == resource.data.requesterId &&
          request.resource.data.recipientId == resource.data.recipientId &&
          request.resource.data.requesterAlias == resource.data.requesterAlias &&
          request.resource.data.recipientAlias == resource.data.recipientAlias &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.keys().hasOnly([
            'requesterId',
            'requesterAlias',
            'recipientId',
            'recipientAlias',
            'status',
            'createdAt',
            'resolvedAt',
            'updatedAt'
          ])
        ) ||
        (
          // Either side can mark an accepted relationship as unlinked.
          (resource.data.requesterId == request.auth.uid || resource.data.recipientId == request.auth.uid) &&
          resource.data.status == 'accepted' &&
          request.resource.data.status == 'unlinked' &&
          request.resource.data.requesterId == resource.data.requesterId &&
          request.resource.data.recipientId == resource.data.recipientId &&
          request.resource.data.requesterAlias == resource.data.requesterAlias &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.keys().hasOnly([
            'requesterId',
            'requesterAlias',
            'recipientId',
            'recipientAlias',
            'status',
            'createdAt',
            'resolvedAt',
            'unlinkedAt',
            'updatedAt'
          ])
        )
      );
      allow delete: if false;
    }

    // Relationship actions (unlink / break sync / manual sync)
    match /relationshipActions/{actionId} {
      allow read: if isAuthenticated() && (
        resource.data.sourceUserId == request.auth.uid ||
        resource.data.targetUserId == request.auth.uid
      );

      allow create: if isAuthenticated() &&
        request.resource.data.initiatedBy == request.auth.uid &&
        request.resource.data.sourceUserId == request.auth.uid &&
        request.resource.data.targetUserId is string &&
        request.resource.data.actionType in ['UNLINK', 'BREAK_SYNC', 'SYNC_NOW'] &&
        request.resource.data.keys().hasOnly([
          'actionType',
          'initiatedBy',
          'sourceUserId',
          'targetUserId',
          'status',
          'createdAt'
        ]) &&
        (
          (
            request.resource.data.actionType == 'UNLINK' &&
            (
              callerHasLinkedTarget(request.resource.data.targetUserId) ||
              targetHasLinkedCaller(request.resource.data.targetUserId)
            )
          ) ||
          (
            request.resource.data.actionType in ['BREAK_SYNC', 'SYNC_NOW'] &&
            callerHasLinkedTarget(request.resource.data.targetUserId)
          )
        );

      allow update, delete: if false;
    }

    // Routine copy/sync requests
    match /routineRequests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid ||
        resource.data.targetUserId == request.auth.uid
      );

      allow create: if isAuthenticated() &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId is string &&
        request.resource.data.toUserId != request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.applyStatus == 'pending' &&
        request.resource.data.keys().hasOnly([
          'fromUserId',
          'fromName',
          'toUserId',
          'toName',
          'sourceUserId',
          'targetUserId',
          'type',
          'status',
          'syncAfterAccept',
          'createdAt',
          'expiresAt',
          'applyStatus'
        ]);

      allow update: if isAuthenticated() && (
        (
          // Recipient accepts/declines
          resource.data.toUserId == request.auth.uid &&
          resource.data.status == 'pending' &&
          request.resource.data.status in ['accepted', 'declined'] &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'resolvedAt',
            'applyStatus',
            'updatedAt'
          ]) &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.sourceUserId == resource.data.sourceUserId &&
          request.resource.data.targetUserId == resource.data.targetUserId &&
          request.resource.data.type == resource.data.type
        ) ||
        (
          // Sender cancels pending request
          resource.data.fromUserId == request.auth.uid &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'cancelled' &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'resolvedAt',
            'updatedAt'
          ]) &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.sourceUserId == resource.data.sourceUserId &&
          request.resource.data.targetUserId == resource.data.targetUserId &&
          request.resource.data.type == resource.data.type
        ) ||
        (
          // Target marks copy as applied
          resource.data.targetUserId == request.auth.uid &&
          resource.data.status == 'accepted' &&
          request.resource.data.applyStatus == 'applied' &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'applyStatus',
            'appliedAt',
            'appliedBy',
            'updatedAt'
          ]) &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.sourceUserId == resource.data.sourceUserId &&
          request.resource.data.targetUserId == resource.data.targetUserId &&
          request.resource.data.type == resource.data.type
        )
      );

      allow delete: if false;
    }

    // Live sessions
    match /liveSessions/{sessionId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;

      allow create: if isAuthenticated() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'active' &&
        request.resource.data.participants is list &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() >= 2 &&
        request.resource.data.keys().hasOnly([
          'sessionId',
          'startTime',
          'routineName',
          'dayName',
          'status',
          'createdBy',
          'participants',
          'createdAt',
          'updatedAt'
        ]);

      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'updatedAt',
          'completedAt',
          'cancelledAt'
        ]) &&
        request.resource.data.status in ['active', 'completed', 'cancelled'] &&
        (
          request.resource.data.status == resource.data.status ||
          (resource.data.status == 'active' && request.resource.data.status in ['completed', 'cancelled'])
        );

      match /participants/{userId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/liveSessions/$(sessionId)).data.participants;
        allow write: if isAuthenticated() &&
          request.auth.uid == userId &&
          request.auth.uid in get(/databases/$(database)/documents/liveSessions/$(sessionId)).data.participants;
      }
    }

    // Training invitations
    match /trainingInvitations/{invitationId} {
      allow read: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );

      allow create: if isAuthenticated() &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId is string &&
        request.resource.data.toUserId != request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.sessionMode in ['shared', 'linked'] &&
        request.resource.data.createdAt is string &&
        request.resource.data.expiresAt is string &&
        request.resource.data.keys().hasOnly([
          'fromUserId',
          'fromName',
          'toUserId',
          'toName',
          'status',
          'sessionMode',
          'routineName',
          'dayName',
          'exercises',
          'trackingDate',
          'liveSessionId',
          'createdAt',
          'expiresAt'
        ]);

      allow update: if isAuthenticated() &&
        resource.data.toUserId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status in ['accepted', 'declined'] &&
        request.resource.data.fromUserId == resource.data.fromUserId &&
        request.resource.data.toUserId == resource.data.toUserId &&
        request.resource.data.fromName == resource.data.fromName &&
        request.resource.data.toName == resource.data.toName &&
        request.resource.data.sessionMode == resource.data.sessionMode &&
        request.resource.data.routineName == resource.data.routineName &&
        request.resource.data.dayName == resource.data.dayName &&
        request.resource.data.exercises == resource.data.exercises &&
        request.resource.data.trackingDate == resource.data.trackingDate &&
        request.resource.data.liveSessionId == resource.data.liveSessionId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.expiresAt == resource.data.expiresAt &&
        request.resource.data.keys().hasOnly([
          'fromUserId',
          'fromName',
          'toUserId',
          'toName',
          'status',
          'sessionMode',
          'routineName',
          'dayName',
          'exercises',
          'trackingDate',
          'liveSessionId',
          'createdAt',
          'expiresAt',
          'resolvedAt',
          'updatedAt'
        ]);

      allow delete: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );
    }
  }
}
